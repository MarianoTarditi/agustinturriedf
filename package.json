{
  "name": "landingpage-opecode",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "agustinturriedf/landing",
    "agustinturriedf/web"
  ],
  "scripts": {
    "dev": "concurrently -n landing,web -c cyan,magenta \"npm run dev --workspace @agustinturriedf/landing\" \"npm run dev --workspace @agustinturriedf/web\"",
    "dev:landing": "npm run dev --workspace @agustinturriedf/landing",
    "dev:web": "npm run dev --workspace @agustinturriedf/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
