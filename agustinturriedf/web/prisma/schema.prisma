generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TRAINER
  STUDENT
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ProfileGender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
}

model User {
  id           String           @id @default(cuid())
  firstName    String
  lastName     String
  email        String           @unique
  phone        String?
  photoUrl     String?
  birthDate    DateTime?
  gender       ProfileGender?
  heightCm     Int?
  weightKg     Int?
  passwordHash String
  role         Role
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  studentProfile StudentProfile? @relation("StudentUserProfile")
  trainerStudents StudentProfile[] @relation("TrainerToStudents")
  trainerConfig   TrainerConfig?   @relation("TrainerConfigOwner")
  recordedPayments PaymentHistory[] @relation("PaymentRecordedByUser")

  @@index([role])
}

model StudentProfile {
  id        String        @id @default(cuid())
  userId    String        @unique
  trainerId String
  status    StudentStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user         User          @relation("StudentUserProfile", fields: [userId], references: [id], onDelete: Cascade)
  trainer      User          @relation("TrainerToStudents", fields: [trainerId], references: [id], onDelete: Restrict)
  routineFolder RoutineFolder?
  currentPayment CurrentPayment?
  paymentHistory PaymentHistory[]

  @@index([trainerId])
  @@index([status])
}

model TrainerConfig {
  id                          String   @id @default(cuid())
  trainerId                   String   @unique
  defaultMonthlyAmountInCents Int      @default(3000000)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  trainer User @relation("TrainerConfigOwner", fields: [trainerId], references: [id], onDelete: Cascade)
}

model CurrentPayment {
  id               String   @id @default(cuid())
  studentProfileId String   @unique
  amountInCents    Int
  startDate        DateTime
  dueDate          DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  paymentHistory PaymentHistory[]

  @@index([studentProfileId])
  @@index([dueDate])
  @@index([startDate])
}

model PaymentHistory {
  id               String   @id @default(cuid())
  studentProfileId String
  currentPaymentId String
  amountInCents    Int
  paymentDate      DateTime
  recordedByUserId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  currentPayment CurrentPayment @relation(fields: [currentPaymentId], references: [id], onDelete: Cascade)
  recordedByUser User           @relation("PaymentRecordedByUser", fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([studentProfileId])
  @@index([paymentDate])
  @@index([recordedByUserId])
}

model RoutineFolder {
  id               String   @id @default(cuid())
  studentProfileId String   @unique
  displayName      String
  storageKey       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  files          RoutineFile[]

  @@index([studentProfileId])
}

model RoutineFile {
  id             String   @id @default(cuid())
  folderId       String
  originalName   String
  normalizedName String
  extension      String
  relativePath   String
  sizeBytes      Int
  observations   String?
  uploadedAt     DateTime @default(now())

  folder RoutineFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, normalizedName])
  @@index([folderId])
  @@index([uploadedAt])
}

model VideotecaFolder {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files VideotecaFile[]

  @@index([updatedAt])
}

model VideotecaFile {
  id           String   @id @default(cuid())
  folderId     String
  originalName String
  normalizedName String
  extension    String
  mediaType    String
  relativePath String
  sizeBytes    Int
  orderIndex   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  folder VideotecaFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([orderIndex])
  @@unique([folderId, normalizedName])
  @@unique([folderId, orderIndex])
}
