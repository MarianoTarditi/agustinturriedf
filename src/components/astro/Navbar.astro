---
const navLinks = [
  { href: "#", label: "Inicio" },
  { href: "#plans", label: "Planes" },
  { href: "#facilities", label: "Instalaciones" },
  { href: "#faq", label: "FAQ" },
  { href: "#contact", label: "Contacto" },
];
---

<nav id="navbar" class="bg-black/70 backdrop-blur-xl fixed top-0 w-full z-50 transition-transform duration-300 shadow-[0px_20px_40px_rgba(123,44,191,0.08)]">
  <div class="flex items-center justify-between w-full px-8 py-6 max-w-none">
    <div class="flex-shrink-0">
      <a href="#" class="flex items-center gap-3 group">
        <img 
          alt="KINETIC NOIR Logo" 
          class="h-14 w-auto object-contain transition-all duration-300 group-hover:scale-105 group-hover:drop-shadow-[0_0_15px_rgba(123,44,191,0.6)]" 
          src="/Logo.png" 
        />
      </a>
    </div>
    <div class="hidden md:flex gap-8 items-center justify-center absolute left-1/2 transform -translate-x-1/2">
      {navLinks.map((link) => (
        <a
          class="nav-link font-headline tracking-tight text-sm font-bold uppercase transition-colors text-gray-400 hover:text-white"
          href={link.href}
          data-section={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex-shrink-0">
      <a
        href="/login"
        class="bg-gradient-to-r from-primary-container to-on-primary-fixed-variant px-6 py-2 rounded-md font-headline text-sm font-bold uppercase text-on-primary-container scale-95 active:scale-90 transition-all hover:scale-105 hover:shadow-[0px_0px_20px_rgba(123,44,191,0.4)] cursor-pointer inline-block"
      >
        Iniciar sesión
      </a>
    </div>
  </div>
</nav>

<script>
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  function updateActiveNav() {
    const scrollPos = window.scrollY + 200;
    
    let activeSectionId = null;
    
    for (const section of sections) {
      const sectionTop = section.offsetTop;
      const sectionHeight = section.offsetHeight;
      if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
        activeSectionId = section.id;
        break;
      }
    }
    
    if (!activeSectionId && scrollPos < 300) {
      activeSectionId = 'hero';
    }

    navLinks.forEach((link) => {
      const linkHref = link.getAttribute('data-section');
      link.classList.remove('text-purple-300', 'border-b-2', 'border-purple-500', 'pb-1');
      link.classList.add('text-gray-400');
      
      if (linkHref === '#' && activeSectionId === 'hero') {
        link.classList.remove('text-gray-400');
        link.classList.add('text-purple-300', 'border-b-2', 'border-purple-500', 'pb-1');
      } else if (linkHref && linkHref !== '#' && activeSectionId && linkHref === `#${activeSectionId}`) {
        link.classList.remove('text-gray-400');
        link.classList.add('text-purple-300', 'border-b-2', 'border-purple-500', 'pb-1');
      }
    });
  }

  navLinks.forEach((link) => {
    link.addEventListener('click', function(e) {
      const linkHref = link.getAttribute('data-section');
      
      navLinks.forEach((l) => {
        l.classList.remove('text-purple-300', 'border-b-2', 'border-purple-500', 'pb-1');
        l.classList.add('text-gray-400');
      });
      link.classList.remove('text-gray-400');
      link.classList.add('text-purple-300', 'border-b-2', 'border-purple-500', 'pb-1');
      
      if (linkHref && linkHref !== '#') {
        const sectionId = linkHref.replace('#', '');
        const section = document.querySelector(`section[id="${sectionId}"]`);
        if (section) {
          e.preventDefault();
          const navHeight = 100;
          const sectionTop = section.offsetTop - navHeight;
          window.scrollTo({
            top: sectionTop,
            behavior: 'smooth'
          });
        }
      } else if (linkHref === '#') {
        e.preventDefault();
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      }
    });
  });

  window.addEventListener('scroll', updateActiveNav);
  updateActiveNav();

  const navbar = document.getElementById('navbar') as HTMLElement;
  let lastScrollY = 0;

  function handleNavbarScroll() {
    const currentScrollY = window.scrollY;
    
    if (currentScrollY > lastScrollY && currentScrollY > 100) {
      navbar?.classList.add('-translate-y-full');
    } else {
      navbar?.classList.remove('-translate-y-full');
    }
    
    lastScrollY = currentScrollY;
  }

  window.addEventListener('scroll', handleNavbarScroll);
</script>
