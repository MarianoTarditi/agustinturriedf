---
const benefits = [
  {
    number: "1",
    icon: "play_circle",
    title: "Videos de ejercicios",
    description:
      "Videoteca exclusiva de movimientos para asegurar la ejecución adecuada.",
  },
  {
    number: "2",
    icon: "sync",
    title: "Correción de técnica",
    description:
      "Mejorá la técnica de tus ejercicios a partir de un feedback constante",
  },
  {
    number: "3",
    icon: "trending_up",
    title: "Progresión semanal",
    description:
      "Seguimiento personalzado de cargas, repeticiones y rendimiento.",
  },
  {
    number: "4",
    icon: "chat",
    title: "Comunicación constante",
    description: "Consultas directas, dudas y seguimiento constante",
  },
];
---

<section class="py-24 bg-surface" id="plans">
  <div class="container mx-auto px-8">
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8"
    >
      <div class="max-w-2xl">
        <h2
          class="font-headline text-4xl md:text-5xl font-black uppercase tracking-tighter mb-4"
        >
          Planes de entrenamiento
        </h2>
        <div class="h-1 w-24 bg-primary-container mb-6"></div>
        <p class="mb-4 text-secondary text-lg">
          Entrenamiento de fuerza personalizado, con foco en el movimiento y la
          calidad del proceso. Evaluar primero, entrenar después, integrando
          salud y rendimiento.
        </p>
      </div>
      <div
        class="font-headline text-primary font-bold text-xl uppercase tracking-widest"
      >
        Rutinas personalizadas
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4" id="plans-grid">
      {
        benefits.map((benefit) => (
          <div class="plan-card group bg-surface-container p-8 rounded-xl flex flex-col justify-between border border-outline-variant/10 transition-all duration-300 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(123,44,191,0.15)] hover:-translate-y-1">
            <div class="flex items-start justify-between">
              <span class="material-symbols-outlined text-primary text-3xl opacity-60 group-hover:opacity-100 transition-opacity">
                {benefit.icon}
              </span>
              <span class="font-headline text-4xl font-black text-primary opacity-50 group-hover:opacity-80 transition-all">
                0{benefit.number}
              </span>
            </div>
            <div class="mt-4">
              <div class="h-0.5 w-8 bg-primary mb-4 opacity-50 group-hover:opacity-100 group-hover:w-full transition-all duration-300"></div>
              <h3 class="font-headline text-lg font-bold uppercase mb-2">
                {benefit.title}
              </h3>
              <p class="text-sm text-secondary leading-relaxed">
                {benefit.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="flex justify-center mt-12">
      <a
        class="bg-gradient-to-r from-primary-container to-on-primary-fixed-variant px-12 py-4 rounded-md font-headline text-lg font-bold uppercase text-on-primary-container scale-100 hover:scale-105 active:scale-105 transition-all flex items-center justify-center"
        href="#contact"
      >
        SOLICITAR PLAN
        <span class="material-symbols-outlined ml-2 align-middle"
          >arrow_downward</span
        >
      </a>
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll('.plan-card');
  
  cards.forEach((card) => {
    card.addEventListener('touchstart', () => {
      cards.forEach((c) => {
        c.classList.remove('border-primary/30', 'shadow-[0_0_30px_rgba(123,44,191,0.15)]', '-translate-y-1');
        c.classList.add('border-outline-variant/10');
      });
      card.classList.remove('border-outline-variant/10');
      card.classList.add('border-primary/30', 'shadow-[0_0_30px_rgba(123,44,191,0.15)]', '-translate-y-1');
    });
    
    card.addEventListener('touchend', () => {
      setTimeout(() => {
        cards.forEach((c) => {
          c.classList.remove('border-primary/30', 'shadow-[0_0_30px_rgba(123,44,191,0.15)]', '-translate-y-1');
          c.classList.add('border-outline-variant/10');
        });
      }, 1500);
    });
  });
</script>
