---
const heroImage =
  "https://lh3.googleusercontent.com/aida-public/AB6AXuBhrOPFrVUAjzJmUH0LjeH1fNbVKOymFwmq4ww1nPzxGNhjf61WvMLb3vLNZnkt7C7duqqlzBy-quZTAmr0fbao9tOtqpkpu2aBKJZzLDofxKDErjDjRNbSUuCbL2XG8AjUSiiwVpXDOKDJ-wWHT_-ATlEd6gnEsGfKzBaXKx4PvjcMb0Pa_FtNEirZaAswkr4yuvumDqVTxZXOe5Jt36MGppUksHL5udOOQL8pRqlTn0lOm-01pSZ-WL-IVohpbx5QNG9O9POPBmrA";

const whatsappNumber = "5492474416101";
const whatsappMessage =
  "Hola Agustin! Quiero solicitar información sobre los planes de entrenamiento.";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<section class="relative h-[921px] flex items-center overflow-hidden pt-20">
  <div class="absolute inset-0 z-0">
    <img
      class="w-full h-full object-cover grayscale opacity-60"
      data-alt="dramatic low-key wide shot of a muscular person lifting heavy iron weights in a dark industrial gym with single overhead light"
      src={heroImage}
    />
    <div class="absolute inset-0 noir-overlay"></div>
  </div>
  <div class="relative z-10 container mx-auto px-8">
    <div class="max-w-4xl">
      <span
        class="inline-block px-4 py-1 mb-6 bg-surface-container-highest rounded-full text-xs font-bold tracking-widest text-primary uppercase"
      >
        El entrenamiento, como cualquier orden de la vida, es un PROCESO.
      </span>
      <h1
        class="font-headline text-6xl md:text-8xl font-bold tracking-tighter leading-[0.9] text-on-surface mb-8 text-glow"
      >
        <span class="text-primary italic">
          <span class="text-[#e2e2e2]" style="font-style: normal;"
            >AGUSTÍN TURRI</span
          >
        </span>
        <div>
          <span class="text-primary italic text-5xl md:text-7xl">ENTRENADOR DE FUERZA</span>
        </div>
      </h1>
      <p
        class="text-lg text-secondary max-w-xl mb-10 leading-relaxed opacity-80"
      >
        Entrenamiento de fuerza personalizado, con foco en el movimiento y la
        calidad del proceso. Evaluar primero, entrenar después, integrando salud
        y rendimiento.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          class="bg-primary-container text-on-primary-container px-10 py-4 rounded-md font-headline font-bold uppercase tracking-widest text-center transition-all hover:scale-105 hover:bg-on-primary-fixed-variant"
          href="#plans"
        >
          Comenzar Ahora
        </a>
        <a
          class="border border-outline-variant text-on-surface px-10 py-4 rounded-md font-headline font-bold uppercase tracking-widest text-center backdrop-blur-md transition-all hover:scale-105 hover:bg-surface-variant hover:border-primary/50 flex items-center justify-center gap-3"
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          Contactáme
          <img
            src="/icons/whatsapp.svg"
            width="24"
            height="24"
            alt="WhatsApp"
          />
        </a>
      </div>
    </div>
  </div>
</section>
